# Este archivo es OPCIONAL. docker-compose.yml ya trae valores por defecto para
# desarrollo, asi que "docker compose up --build" funciona sin copiar este archivo.
# Copielo a .env solo si quiere cambiar contrasenas, puertos u otros ajustes.

SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong!Passw0rd
SQLSERVER_DB=citari

# Puerto del host para conectar DataGrip/DBeaver/SSMS a la base dockerizada.
# Se usa 11433 por defecto para no chocar con un SQL Server local en 1433.
SQLSERVER_HOST_PORT=11433

API_PORT=8000
FRONTEND_PORT=3000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_MODE=api

# Secret used to sign/verify API JWTs (HS256). Must be 32+ chars. Generate a
# real value for each environment, e.g.: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-32-plus-character-secret
JWT_EXPIRES_MIN=60
CORS_ORIGINS=http://localhost:3000
LOG_FORMAT=json
