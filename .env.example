JWT_SECRET=replace-with-a-random-32-plus-character-secret
JWT_EXPIRES_MIN=60
CORS_ORIGINS=http://localhost:3000
LOG_FORMAT=json

# Notion integration (optional)
NOTION_TOKEN=
NOTION_PAGE_ID=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
